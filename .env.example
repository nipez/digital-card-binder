NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=only-for-server-side-seed-or-admin-scripts
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
ADMIN_UPLOAD_TOKEN=make-a-long-random-admin-upload-password

# Optional: used by npm run scrape-card-set-images.
# Add one provider key to .env.local when you want broad web image discovery.
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=
